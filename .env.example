# Required: BotFather token. Inject as a secret in production; never commit a
# real value. The container reads this from env at startup.
BOT_TOKEN=

# Optional: Production session/data store. When set, the toolkit uses Redis
# (via ioredis) for both per-chat sessions and durable domain data. Omit in
# dev to fall back to an in-memory store.
# REDIS_URL=redis://localhost:6379

# Optional: Comma-separated Telegram user IDs to seed as admins at startup.
# When empty, the first user to invoke /admin can claim owner access.
# ADMIN_TELEGRAM_IDS=123456789,987654321