[
  {
    "name": "reviews empty state when there are no reviews",
    "steps": [
      {
        "send": { "callback": "reviews:list" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "⭐ Reviews\n\nNo reviews yet — be the first!" }
          }
        ]
      }
    ]
  },
  {
    "name": "review:start refuses for a booking that's not ready",
    "steps": [
      {
        "send": { "callback": "review:start:nonexistent" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "That booking isn't ready for a review yet." }
          }
        ]
      }
    ]
  },
  {
    "name": "review cancel clears the review flow",
    "steps": [
      {
        "send": { "callback": "review:cancel" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Review cancelled." }
          }
        ]
      }
    ]
  },
  {
    "name": "review:done calls submitReview and shows incomplete when no flow active",
    "steps": [
      {
        "send": { "callback": "review:done" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "Review incomplete. Try again." }
          }
        ]
      }
    ]
  },
  {
    "name": "review:photos for a nonexistent review says not available",
    "steps": [
      {
        "send": { "callback": "review:photos:nonexistent" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Photos not available." }
          }
        ]
      }
    ]
  },
  {
    "name": "review:prompt-dismiss edits after prompting is dismissed",
    "steps": [
      {
        "send": { "callback": "review:prompt-dismiss" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "No problem — you can leave a review any time from the ⭐ Reviews menu." }
          }
        ]
      }
    ]
  }
]