[
  {
    "name": "non-admin gets the claim screen when no admins exist",
    "steps": [
      {
        "send": { "text": "/admin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🔐 No admin set yet.\n\nTap below to claim owner access. Once set, you can add more admins from the admin menu."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "second claim attempt is rejected after first claim succeeded",
    "steps": [
      { "send": { "text": "/admin" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:claim" }, "expect": [{ "method": "editMessageText" }] },
      {
        "send": { "callback": "admin:claim" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🔐 Admin already exists." }
          }
        ]
      }
    ]
  },
  {
    "name": "admin CRUD: add a service and then delete it",
    "steps": [
      { "send": { "text": "/admin" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:claim" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:services" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:service-new" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "text": "Glow Facial" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "Hydrating facial" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "79" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "60" }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "admin:services" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "admin:service-edit:Glow Facial" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "💅 Glow Facial\nHydrating facial\nPrice: $79.00 · Duration: 60 min"
            }
          }
        ]
      },
      {
        "send": { "callback": "admin:service-delete:Glow Facial" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🗑 Service deleted." }
          }
        ]
      }
    ]
  },
  {
    "name": "admin CRUD: add a staff member and remove them",
    "steps": [
      { "send": { "text": "/admin" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:claim" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:staff" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:staff-new" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "text": "Maria" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "all" }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "admin:staff" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "admin:staff-edit:Maria" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "admin:staff-delete:Maria" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🗑 Staff removed." }
          }
        ]
      }
    ]
  },
  {
    "name": "admin CSV export sends a document",
    "steps": [
      { "send": { "text": "/admin" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:claim" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:service-new" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "text": "Glow Facial" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "Hydrating facial" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "79" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "60" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "booking:start:Glow Facial" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "booking:slot:2099-01-01T09:00:00.000Z" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "text": "Alex" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "+15551234567" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "booking:confirm" }, "expect": [{ "method": "editMessageText" }] },
      {
        "send": { "callback": "admin:export" },
        "expect": [{ "method": "sendDocument" }]
      }
    ]
  },
  {
    "name": "admin adds a new admin by Telegram ID",
    "steps": [
      { "send": { "text": "/admin" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:claim" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:admins" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:admin-new" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "text": "555" }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "admin:admins" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "admin:admin-remove:555" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🔐 Removed admin 555." }
          }
        ]
      }
    ]
  },
  {
    "name": "admin edits a service name via the edit flow",
    "steps": [
      { "send": { "text": "/admin" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:claim" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:service-new" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "text": "Basic Facial" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "Simple cleansing" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "50" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "30" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:services" }, "expect": [{ "method": "editMessageText" }] },
      { "send": { "callback": "admin:service-edit:Basic Facial" }, "expect": [{ "method": "editMessageText" }] },
      {
        "send": { "callback": "admin:service-edit-field:Basic Facial" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "✏️ Edit “Basic Facial”\n\nPick a field to update:" }
          }
        ]
      },
      {
        "send": { "callback": "admin:service-edit-do:Basic Facial:edit_name" },
        "expect": [{ "method": "editMessageText" }]
      },
      { "send": { "text": "Deluxe Facial" }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "admin:services" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  },
  {
    "name": "admin views and updates studio settings",
    "steps": [
      { "send": { "text": "/admin" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "admin:claim" }, "expect": [{ "method": "editMessageText" }] },
      {
        "send": { "callback": "admin:settings" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "admin:settings-edit:start_hour" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🕐 Send start hour (0–23, e.g. 9):" }
          }
        ]
      },
      { "send": { "text": "8" }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "admin:settings" },
        "expect": [{ "method": "editMessageText" }]
      },
      {
        "send": { "callback": "admin:settings-edit:slot_minutes" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "⏱ Send slot interval in minutes (5–240):" }
          }
        ]
      },
      { "send": { "text": "30" }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "admin:settings" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]